[Unit]
Description=Gunicorn instance to serve FastAPI Backend
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/plataforma_web/backend
Environment="PATH=/var/www/plataforma_web/backend/venv/bin"
ExecStart=/var/www/plataforma_web/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always

[Install]
WantedBy=multi-user.target